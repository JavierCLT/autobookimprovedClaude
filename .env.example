# Required
OPENAI_API_KEY=sk-...

# Model configuration (optional)
OPENAI_MODEL=gpt-5.4
OPENAI_DRAFTING_MODEL=          # separate model for prose (e.g. claude-opus-4-6)
OPENAI_QA_MODEL=                # separate model for QA/judging

# Pipeline configuration (optional)
NOVEL_FACTORY_RUN_ROOT=runs
NOVEL_FACTORY_DEFAULT_AUDIENCE=Adult
NOVEL_FACTORY_DEFAULT_RATING_CEILING=R
NOVEL_FACTORY_DEFAULT_MARKET_POSITION=adult thriller

# Contest-grade settings (optional)
NOVEL_FACTORY_BEST_OF_N=3           # generate N drafts per scene, pick best
NOVEL_FACTORY_BEST_OF_N_ENABLED=true
NOVEL_FACTORY_MAX_REWRITES=4        # max rewrite attempts per scene
NOVEL_FACTORY_MAX_REPAIR_CYCLES=3   # max global QA -> repair loops
